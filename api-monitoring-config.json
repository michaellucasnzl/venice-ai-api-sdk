{
  "apiMonitoring": {
    "sourceUrl": "https://api.venice.ai/api/v1/swagger.yaml",
    "baselineFile": "openapi/venice-ai-api.yaml",
    "latestFile": "openapi/latest-venice-ai-api.yaml",
    "schedule": "0 2 * * *",
    "notifications": {
      "email": [],
      "slack": "",
      "teams": ""
    }
  },
  "generation": {
    "tool": "nswag",
    "configFile": "nswag.json",
    "outputPath": "src/VeniceAI.SDK/Generated/VeniceAIGeneratedClient.cs",
    "namespace": "VeniceAI.SDK.Generated",
    "className": "VeniceAIGeneratedClient"
  },
  "changeDetection": {
    "ignoredPaths": [
      "info.version",
      "info.description"
    ],
    "criticalPaths": [
      "paths",
      "components.schemas",
      "components.responses"
    ],
    "breakingChangePatterns": [
      "removed path",
      "removed schema",
      "removed property",
      "changed type"
    ]
  },
  "testing": {
    "unitTestFilter": "Category!=Integration",
    "buildConfiguration": "Release",
    "runTestsOnGeneration": true
  },
  "versioning": {
    "strategy": "date",
    "prefix": "1.0",
    "autoIncrement": true
  }
}
